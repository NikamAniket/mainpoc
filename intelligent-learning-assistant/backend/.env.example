PORT=5000
GCP_LOCATION=us-central1
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
NODE_ENV=development

# Note: Vertex AI uses Google Application Default Credentials (ADC).
# Ensure you have set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON
# or run `gcloud auth application-default login` on your local machine.
GOOGLE_APPLICATION_CREDENTIALS=path_to_your_service_account_json
